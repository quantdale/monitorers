{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "System Monitor",
  "version": "0.1.4",
  "identifier": "com.quantdale.systemmonitor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5180",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "System Monitor",
        "width": 900,
        "height": 1100,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "quantdale",
    "copyright": "Copyright © 2025 quantdale",
    "shortDescription": "Real-time hardware performance monitor",
    "longDescription": "System Monitor displays real-time CPU, GPU, memory, disk, and network metrics with historical charts and hardware specs."
  }
}
